{
  "manifest_version": 3,
  "name": "OneSignal Dashboard Translator",
  "version": "1.0.0",
  "description": "Translate the OneSignal dashboard UI into Japanese, Spanish, or Portuguese.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://dashboard.onesignal.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OneSignal Translator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://dashboard.onesignal.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["languages.json"],
      "matches": ["https://dashboard.onesignal.com/*"]
    }
  ]
}
